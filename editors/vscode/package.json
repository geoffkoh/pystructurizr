{
  "name": "pystructurizr-vscode",
  "displayName": "pystructurizr",
  "description": "Structurizr DSL syntax highlighting and interactive C4 diagram preview, powered by pystructurizr.",
  "version": "0.2.0",
  "publisher": "geoffkoh",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/geoffkoh/pystructurizr"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "structurizr-dsl",
        "aliases": [
          "Structurizr DSL",
          "structurizr"
        ],
        "extensions": [
          ".dsl",
          ".structurizr"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "structurizr-dsl",
        "scopeName": "source.structurizr-dsl",
        "path": "./syntaxes/structurizr-dsl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "pystructurizr.openPreview",
        "title": "Open Diagram Preview",
        "category": "Pystructurizr",
        "icon": "$(type-hierarchy-sub)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "pystructurizr.openPreview",
          "when": "editorLangId == structurizr-dsl",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "pystructurizr.openPreview",
          "when": "editorLangId == structurizr-dsl"
        }
      ]
    },
    "configuration": {
      "title": "pystructurizr",
      "properties": {
        "pystructurizr.serverCommand": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Command used to launch the preview server (the `webapp` subcommand and port are appended). Leave empty for automatic resolution: `pystructurizr` on PATH \u2192 the workspace project via `uv run` \u2192 `uv tool run` from PyPI \u2192 a one-time download of uv. Set explicitly to pin an environment, e.g. `[\"pystructurizr\"]` or a venv script path."
        },
        "pystructurizr.backendSpec": {
          "type": "string",
          "default": "",
          "markdownDescription": "Package spec the automatic `uv tool run` rungs install (default: the pinned `pystructurizr-studio` release matching this extension). Override for pre-releases, e.g. `git+https://github.com/geoffkoh/pystructurizr` or a local wheel path."
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "compile": "npm run typecheck && esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --watch",
    "vscode:prepublish": "npm run compile",
    "package": "npm run compile && vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5",
    "@vscode/vsce": "^2.26.0"
  },
  "license": "MIT"
}
