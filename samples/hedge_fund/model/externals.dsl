// External counterparties, vendors and venues.

vendorData   = softwareSystem "Market Data Vendor" "Bloomberg B-PIPE / Refinitiv real-time and reference data" "External System"
venues       = softwareSystem "Execution Venues" "Exchanges, ECNs and dark pools reached over FIX" "External System"
primeBroker  = softwareSystem "Prime Broker" "Financing, stock borrow, clearing and give-ups" "External System"
custodian    = softwareSystem "Custodian" "Safekeeping of assets and settlement confirmation" "External System"
fundAdmin    = softwareSystem "Fund Administrator" "Independent NAV calculation and investor reporting" "External System"
regGateway   = softwareSystem "Regulatory Gateway" "MiFID II / CAT transaction reporting venue" "External System"
